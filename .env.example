ANTHROPIC_API_KEY=your_api_key_here

# Publishing — set to true to enable social media uploads
PUBLISHING_ENABLED=true

# YouTube Shorts — obtain via: python setup_credentials.py --platform youtube
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# TikTok — obtain via: python setup_credentials.py --platform tiktok
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_ACCESS_TOKEN=your_access_token_here
TIKTOK_REFRESH_TOKEN=your_refresh_token_here

# Instagram Reels — obtain via: python setup_credentials.py --platform instagram
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here
